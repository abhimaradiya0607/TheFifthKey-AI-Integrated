<%layout('/layouts/boilerplate')%>
<div class="row">
    <div class="col-8 offset-3">
            <h1>Listing Details</h1>
        </div>
            <div class="card col-6 offset-3 show-card">
                <img src="<%=listing.image.url%>" class="card-img-top show-img" onerror="this.src='/images/default-img.jpg';">
                <div class="card-body">
                <p class="card-text"><b><%=listing.title%></b><br>
                    <br>

                    <%=listing.description%><br>
                    &#8377;<%=listing.price.toLocaleString("en-In")%><br>
                    <%=listing.location%><br>
                    <%=listing.country%><br>
                </p>
                </div>
            </div>
            <div class="btns">
                <a href="/listing/<%=listing._id%>/edit" class="btn col-3 offset-3" style="background-color: green !important;">Edit this Listing</a>       
            <form method="post" action="/listing/<%=listing._id%>?_method=Delete">
                <button type="submit" class="btn col-8 offset-3" style="background-color: red !important;">Delete This listing</button>
            </form>
    </div>

