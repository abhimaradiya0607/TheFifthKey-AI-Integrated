<%layout('/layouts/boilerplate')%>

<div class="container py-5">

  <!-- Title -->
  <div class="row mb-3">
    <div class="col-lg-8 offset-lg-2">
      <h1 class="show-title"><%=listing.title%></h1>
    </div>
  </div>

  <!-- Listing Card -->
  <div class="row mb-4">
    <div class="col-lg-8 offset-lg-2">
      <div class="show-card-wrapper">
        <img src="<%=listing.image.url%>" class="show-main-img" onerror="this.src='/images/default-img.jpg';">
        <div class="show-details">
          <p class="show-description"><%=listing.description%></p>
          <div class="show-meta">
            <span class="show-price">&#8377;<%=listing.price.toLocaleString("en-IN")%> <span class="per-night">/ night</span></span>
            <span class="show-location">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
              </svg>
              <%=listing.location%>, <%=listing.country%>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="row mb-4">
    <div class="col-lg-8 offset-lg-2">
      <div class="action-btns">
        <a href="/listing/<%=listing._id%>/edit" class="btn-edit">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
          </svg>
          Edit Listing
        </a>
        <form method="post" action="/listing/<%=listing._id%>?_method=Delete">
          <button type="submit" class="btn-delete">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
              <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
            </svg>
            Delete Listing
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <hr class="section-divider">
    </div>
  </div>

  <!-- Review Form -->
  <div class="row mt-4">
    <div class="col-lg-8 offset-lg-2">
      <div class="review-section">
        <h4 class="review-title">Leave a Review</h4>

        <form method="post" action="/listing/<%=listing._id%>/reviews">

          <!-- Star Rating -->
          <div class="mb-4">
            <label class="review-label">Your Rating</label>
            <div class="star-rating" id="starRating">
              <% for(let i = 5; i >= 1; i--) { %>
                <input type="radio" name="review[rating]" id="star<%=i%>" value="<%=i%>">
                <label for="star<%=i%>" title="<%=i%> stars">&#9733;</label>
              <% } %>
            </div>
          </div>

          <!-- Comment -->
          <div class="mb-4">
            <label class="review-label" for="comment">Your Comment</label>
            <textarea
              name="review[comment]"
              id="comment"
              rows="4"
              class="review-textarea"
              placeholder="Share your experience with this property..."></textarea>
          </div>

          <button type="submit" class="btn-submit">
            Submit Review
          </button>

        </form>
      </div>
    </div>
  </div>

</div>