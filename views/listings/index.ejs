<%layout('/layouts/boilerplate')%>
<body>
    <h1>All Listings</h1>
    <!-- <form method="get" action="/listing/new">
        <button>Add New Lisitng</button>
    </form> -->
    <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <%for(listing of allListings){%>
            <div class="card col">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="..." style="height: 20rem;">
                <div class="card-img-overlay">abcd</div>
                <div class="card-body">
                  <p class="card-text"><b><%=listing.title%><br></b>
                    &#8377; <%=listing.price.toLocaleString("en-IN")%> / night
                </p>
                </div>
              </div>
              <%}%>
    </div>
</a>
</body>


