<% if (success && success.length> 0) { %>
    <div id="flash-success" data-message="<%= success[0] %>" style="display: none"></div>
    <% } %>
        <% if (error && error.length> 0) { %>
            <div id="flash-error" data-message="<%= error[0] %>" style="display: none"></div>
            <% } %>
                <% if (info && info.length> 0) { %>
                    <div id="flash-info" data-message="<%= info[0] %>" style="display: none"></div>
                    <% } %>
                        <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top" id="tfkNavbar">
