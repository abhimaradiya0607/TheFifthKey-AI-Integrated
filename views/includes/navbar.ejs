                        </nav>
                        <div class="modal fade" id="authModal" tabindex="-1" aria-label="Authentication"
                            aria-modal="true" role="dialog">
                            <div class="modal-dialog modal-dialog-centered" style="max-width: 860px">
                                <div class="modal-content border-0 overflow-hidden" style="
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(11, 31, 58, 0.18);
      ">
                                    <div class="modal-body p-0 d-flex" style="min-height: 540px">
                                        <div class="auth-image-panel d-none d-md-flex" style="
            flex: 0 0 42%;
            position: relative;
            overflow: hidden;
            background: var(--navy);
          ">
                                            <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=800&q=80"
                                                alt="" style="
              width: 100%;
              height: 100%;
              object-fit: cover;
              opacity: 0.45;
              filter: saturate(0.7);
            " />

                                            <button type="button" class="tfk-modal-close" data-bs-dismiss="modal"
                                                aria-label="Close">
                                                <i class="bi bi-x-lg"></i>
                                            </button>

                                            <div class="auth-image-overlay">
                                                <div class="brand-mark">
                                                    <div class="logo-circle">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                                            <path
                                                                d="M12.65 10A6 6 0 1 0 11 16H13l1.5 1.5L16 16l1.5 1.5L19 16l-1.5-1.5L19 13H11a4 4 0 1 1 1.65-3z" />
                                                        </svg>
                                                    </div>
                                                    <span>The Fifth Key</span>
                                                </div>

                                                <div>
                                                    <div class="auth-ornament"></div>
                                                    <h2 class="auth-panel-headline">
                                                        Unlock Your Next<br />
                                                        <em>Luxury Stay</em>
                                                    </h2>
                                                    <p class="auth-panel-sub">
                                                        Experience handpicked luxury properties around the world.
                                                    </p>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="auth-form-panel" style="
            flex: 1;
            padding: 2.5rem 2.75rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #fff;
            position: relative;
          ">
                                            <button type="button" class="d-md-none position-absolute btn-close"
                                                data-bs-dismiss="modal" aria-label="Close"
                                                style="top: 1rem; right: 1rem"></button>

                                            <div id="loginFormWrap"><%- include('../users/loginform') %></div>

                                            <div id="signupFormWrap" style="display: none">
                                                <%- include('../users/signupform') %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <script>
                            function showLogin() {
                                const loginWrap = document.getElementById("loginFormWrap");
                                const signupWrap = document.getElementById("signupFormWrap");
                                if (!loginWrap || !signupWrap) return;
                                signupWrap.style.display = "none";
                                loginWrap.style.display = "block";
                            }

                            function showSignup() {
                                const loginWrap = document.getElementById("loginFormWrap");
                                const signupWrap = document.getElementById("signupFormWrap");
                                if (!loginWrap || !signupWrap) return;
                                loginWrap.style.display = "none";
                                signupWrap.style.display = "block";
                            }

                            document.addEventListener("DOMContentLoaded", function () {
                                const loginBtn = document.getElementById("openLoginBtn");
                                const signupBtn = document.getElementById("openSignupBtn");

                                if (loginBtn) loginBtn.addEventListener("click", showLogin);
                                if (signupBtn) signupBtn.addEventListener("click", showSignup);

                                const authModal = document.getElementById("authModal");

                                if (authModal) {
                                    authModal.addEventListener("hidden.bs.modal", function () {
                                        showLogin();
                                    });
                                }
                                const flashError = document.getElementById("flash-error");

                                      if (flashError && authModal) {
        showSignup();

        const modal = new bootstrap.Modal(authModal);

        modal.show();

    }
                            });

                            
                        </script>