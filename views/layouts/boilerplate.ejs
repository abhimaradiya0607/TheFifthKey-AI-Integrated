<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== "undefined" ? title : "The Fifth Key" %></title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <!-- Google Fonts — Cormorant Garamond (display) + Jost (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Your existing styles -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- The Fifth Key Luxury CSS (add AFTER style.css so it can override) -->
    <link rel="stylesheet" href="/css/luxury.css">
</head>
<body>

    <!-- Navbar + Mobile Menu + Auth Modal + Toast Container (all in one include) -->
    <%- include('../includes/navbar.ejs') %>

    <!-- Main page content -->
    <div class="container">
        <%- body %>
    </div>

    <!-- Footer -->
    <%- include('../includes/footer.ejs') %>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <!-- The Fifth Key Luxury JS (MUST come after Bootstrap JS) -->
    <script src="/javascript/luxury.js"></script>

    <!-- Your existing script.js -->
    <script src="/javascript/script.js"></script>

</body>
</html>